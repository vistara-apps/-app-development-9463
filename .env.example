# SoulConnect Environment Configuration

# OpenAI API Key (via OpenRouter)
# Get your API key from: https://openrouter.ai/
VITE_OPENAI_API_KEY=your_openrouter_api_key_here

# WalletConnect Project ID (optional, for enhanced wallet support)
# Get your project ID from: https://cloud.walletconnect.com/
VITE_WALLET_CONNECT_PROJECT_ID=your_project_id_here

# Payment API Base URL (default: Vistara payments)
VITE_PAYMENT_API_URL=https://payments.vistara.dev

# App Configuration
VITE_APP_NAME=SoulConnect
VITE_APP_VERSION=1.0.0

# Development Configuration
VITE_DEV_MODE=true
VITE_DEBUG_PAYMENTS=false
